# HAProxy Template IC Environment Variables Example
# Copy this file to .env in your project root for local development

# Core Configuration (Required)
CONFIGMAP_NAME=haproxy-template-ic-config

# Server Ports
HEALTHZ_PORT=8080
METRICS_PORT=9090

# Logging Configuration
VERBOSE=1
STRUCTURED_LOGGING=true

# File Paths
SOCKET_PATH=/run/haproxy-template-ic/management.sock

# Feature Flags
DEVELOPMENT_MODE=false

# Distributed Tracing Configuration
TRACING_ENABLED=true
TRACING_SERVICE_NAME=haproxy-template-ic
TRACING_SERVICE_VERSION=1.0.0
TRACING_JAEGER_ENDPOINT=jaeger-collector:14268
TRACING_SAMPLE_RATE=0.1
TRACING_CONSOLE_EXPORT=false

# Webhook Server Configuration
WEBHOOK_ENABLED=true
WEBHOOK_PORT=9443
WEBHOOK_CERT_DIR=/tmp/webhook-certs

# Security (Optional)
# API_KEY=your-secret-api-key

# Nested Configuration Examples (using double underscores)
# TRACING__ENABLED=true
# TRACING__SERVICE_NAME=my-service
# WEBHOOK__PORT=8443